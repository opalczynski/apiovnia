# =============================================================================
# Apiovnia .gitignore — single source of truth at the repo root.
# Organized by domain; patterns apply recursively to subdirectories.
# =============================================================================

# -----------------------------------------------------------------------------
# Local environment / dev shims (per-machine PATH, secrets, …)
# -----------------------------------------------------------------------------
.envrc.local
.envrc.*.local
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Node / pnpm / Vite
# -----------------------------------------------------------------------------
node_modules/
# Vite production bundle output
apiovnia-app/dist/
# Vite resolved-config cache + timestamp probe files
.vite/
*.timestamp-*.mjs
*.timestamp-*.js

# -----------------------------------------------------------------------------
# Rust / Cargo / Tauri
# -----------------------------------------------------------------------------
# Cargo build artefacts (everything in `target/` is regenerable; lockfile lives
# at apiovnia-app/src-tauri/Cargo.lock and IS committed — this is a binary).
target/
# Tauri-generated schema files for capability autocomplete
apiovnia-app/src-tauri/gen/schemas/
# Tauri bundle output (DMG, deb, AppImage, MSI, …)
apiovnia-app/src-tauri/target/bundle/
# WiX toolset cache (Windows installer)
apiovnia-app/src-tauri/WixTools/

# -----------------------------------------------------------------------------
# TypeScript / Svelte
# -----------------------------------------------------------------------------
*.tsbuildinfo
# SvelteKit leftovers from the scaffold (we don't use SvelteKit but harmless)
.svelte-kit/

# -----------------------------------------------------------------------------
# Logs / debugger output
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
# Cargo build logs
cargo-timing-*.html

# -----------------------------------------------------------------------------
# Test coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
tarpaulin-report.*

# -----------------------------------------------------------------------------
# Local SQLite dumps / databases
# Apiovnia's real DB lives at ~/.local/share/tech.trurl.apiovnia/apiovnia.db
# (user data, never inside the repo). Anything matching `*.db` inside the
# repo is therefore a stray test dump and should not be committed.
# -----------------------------------------------------------------------------
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Editors / IDEs
# (We commit .vscode/extensions.json + .vscode/settings.json on purpose
#  so contributors get matching recommendations — only noise is ignored.)
# -----------------------------------------------------------------------------
.vscode/*.log
.vscode/.history/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Misc scratch
# -----------------------------------------------------------------------------
tmp/
*.bak
*.orig
*.rej
