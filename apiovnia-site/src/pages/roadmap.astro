---
import BaseLayout from "../layouts/BaseLayout.astro";

const phases = [
  { id: "0",    title: "Bootstrap",                                                                              status: "done", note: "Three-panel layout, design tokens, fonts, dev shell" },
  { id: "1",    title: "Storage + CRUD",                                                                          status: "done", note: "SQLite, projects/collections/requests CRUD in UI" },
  { id: "1.5",  title: "Custom dialogs + context menus",                                                          status: "done", note: "Replaces native prompt/confirm" },
  { id: "2",    title: "Request editor",                                                                          status: "done", note: "URL bar, method, params/headers/body/auth tabs, CodeMirror, debounced save" },
  { id: "3",    title: "HTTP execution + response viewer",                                                        status: "done", note: "reqwest + rustls, gzip, redirects, history persisted" },
  { id: "4",    title: "Rich JSON viewer",                                                                        status: "done", note: "Collapsible nodes, ⌘F search, hover-copy, expand/collapse-all" },
  { id: "5",    title: "Environments + per-request overrides + {{var}}",                                          status: "done", note: "Pure resolver in apiovnia-core (33 tests)" },
  { id: "5.5",  title: "Multipart bodies (text + file parts)",                                                    status: "done", note: "tauri-plugin-dialog file picker, RFC-7578 preview" },
  { id: "5.6",  title: "Filters, cascade auto-pick, empty-state CTAs",                                            status: "done", note: "Send-elapsed timer, smart no-project / no-collection / no-request states" },
  { id: "6",    title: "Master-password sealing per environment",                                                 status: "done", note: "Argon2id + AES-256-GCM, zxcvbn meter, 10 min idle auto-lock (21 tests)" },
  { id: "7",    title: "OpenAPI 3.x import + export",                                                             status: "done", note: "$ref resolution, schema inference, secret scrubbing, OpLog panel (56 tests + 1 integration)" },
  { id: "8",    title: "Command palette + Copy as… (5 formats)",                                                  status: "done", note: "Fuzzy ranking, env actions, curl/Python/HTTPie/JS/PowerShell (43 tests)" },
  { id: "9",    title: "History panel · ⌘1/2/3 · onboarding overlay",                                             status: "done", note: "~200 executions with filter, navigate + rehydrate" },
  { id: "9.5",  title: "App icon, TitleBar logo, footer version, UI polish",                                      status: "done", note: "Honeycomb master SVG, shortcut swap (⌘P palette / ⌘K filter)" },
  { id: "11",   title: "Settings panel + five themes",                                                            status: "done", note: "apiovnia / atomic-dark / tokyo-night / monokai / light" },
  { id: "13.1", title: "GraphQL — query + variables editor, POST + GET execution",                                status: "done", note: "JSON-body POST + URL-string GET per the GraphQL-over-HTTP spec (13 tests)" },

  { id: "9 (pkg)", title: "Packaging — .deb / .AppImage / .dmg / .msi · signing",                                 status: "next", note: "tauri.conf.json has bundle.targets but no signing config" },

  { id: "10", title: "Security & UX hardening",                                                                   status: "scoped", note: "Configurable lock timeout, change-password flow, per-field secrets, hardware keychain wrap" },
  { id: "12", title: "Settings expansion",                                                                        status: "scoped", note: "Send timeout, proxy/TLS, UI density, clear-history" },
  { id: "13", title: "Multi-protocol support — SSE, then MCP",                                                    status: "scoped", note: "MCP via Streamable HTTP reuses SSE plumbing. WebSocket + gRPC deferred" },
  { id: "14", title: "CI + release automation",                                                                   status: "future", note: "GitHub Actions + tauri-action → GitHub Releases" },
  { id: "15", title: "Docs / landing site",                                                                       status: "future", note: "You are here." },
];

const groups = {
  done:   phases.filter((p) => p.status === "done"),
  next:   phases.filter((p) => p.status === "next"),
  scoped: phases.filter((p) => p.status === "scoped"),
  future: phases.filter((p) => p.status === "future"),
};
---
<BaseLayout
  title="Roadmap — Apiovnia"
  description="Where Apiovnia stands today, what ships next, and what is deliberately out of scope. The plan is short on purpose."
>
  <section class="page-head">
    <div class="container">
      <span class="eyebrow">Roadmap</span>
      <h1>Short, on purpose.</h1>
      <p class="lead">
        Apiovnia is a single-developer product, not a platform. Every phase ships something you can run; there are no internal-only milestones. The full log lives in <code>plan.md</code> in the repo — this page is the readable summary.
      </p>

      <div class="legend">
        <span><span class="dot done"></span> Done</span>
        <span><span class="dot next"></span> Next</span>
        <span><span class="dot scoped"></span> Scoped, not started</span>
        <span><span class="dot future"></span> Future</span>
      </div>
    </div>
  </section>

  <hr class="glow-divider" />

  {(["next", "done", "scoped", "future"] as const).map((key) => (
    <section class="grp">
      <div class="container">
        <h2 class="grp-title">
          {key === "next"   && <>Next up <span class="status warn">in progress</span></>}
          {key === "done"   && <>Shipped <span class="status ok">{groups.done.length}</span></>}
          {key === "scoped" && <>Scoped, not started</>}
          {key === "future" && <>On the horizon</>}
        </h2>
        <ul class="phases">
          {groups[key].map((p) => (
            <li class={`phase ${p.status}`}>
              <div class="phase-id">Phase {p.id}</div>
              <div class="phase-title">{p.title}</div>
              <div class="phase-note">{p.note}</div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <section class="oos">
    <div class="container">
      <span class="eyebrow">Out of scope, on purpose</span>
      <h2>What stays off this page.</h2>
      <ul class="oos-list">
        <li>Pre-request scripts</li>
        <li>Response test assertions</li>
        <li>Team workspaces</li>
        <li>Sync — any direction, any provider</li>
        <li>Browser version</li>
        <li>Mobile</li>
        <li>Auto-updater</li>
        <li>Drag-to-reorder</li>
      </ul>
      <p>
        WebSocket / SSE / gRPC / GraphQL were once on this list. GraphQL shipped because the absence finally cost more than the addition. SSE and MCP are queued in Phase 13 for the same reason. Everything else is here because adding it would change what Apiovnia is.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { padding: var(--space-9) 0 var(--space-7); }
  .page-head h1 { margin-top: var(--space-4); }
  .lead { margin-top: var(--space-5); max-width: 720px; font-size: 17px; color: var(--fg-dim); }

  .legend {
    margin-top: var(--space-6);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    font-size: 13px;
    color: var(--fg-muted);
  }
  .legend span { display: inline-flex; align-items: center; gap: 8px; }
  .legend .dot { width: 10px; height: 10px; border-radius: 50%; }
  .legend .dot.done   { background: var(--ok); }
  .legend .dot.next   { background: var(--accent); box-shadow: 0 0 0 3px rgba(245,158,11,0.18); }
  .legend .dot.scoped { background: var(--fg-muted); }
  .legend .dot.future { background: var(--fg-faint); }

  .grp { padding: var(--space-7) 0; }
  .grp-title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 22px;
  }
  .phases {
    margin-top: var(--space-5);
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-3);
  }
  .phase {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    padding: var(--space-4) var(--space-5);
    position: relative;
  }
  .phase::before {
    content: "";
    position: absolute;
    left: -1px; top: 14px; bottom: 14px;
    width: 3px;
    border-radius: 2px;
    background: var(--fg-faint);
  }
  .phase.done::before   { background: var(--ok); }
  .phase.next::before   { background: var(--accent); box-shadow: 0 0 12px var(--accent); }
  .phase.scoped::before { background: var(--fg-muted); }
  .phase.future::before { background: var(--fg-faint); }
  .phase-id {
    font: 600 11px/1 var(--mono);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .phase-title {
    margin-top: 6px;
    font-size: 14.5px;
    font-weight: 600;
    color: var(--fg);
    line-height: 1.35;
  }
  .phase-note {
    margin-top: 6px;
    font-size: 12.5px;
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .oos {
    padding: var(--space-7) 0 var(--space-9);
    background: var(--surface);
    border-top: 1px solid var(--border);
  }
  .oos h2 { margin-top: var(--space-3); }
  .oos-list {
    margin-top: var(--space-5);
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-3);
  }
  .oos-list li {
    padding: var(--space-3) var(--space-4);
    border: 1px dashed var(--border-strong);
    border-radius: var(--r-ctrl);
    color: var(--fg-dim);
    font-size: 13.5px;
  }
  .oos p {
    margin-top: var(--space-5);
    max-width: 640px;
    font-size: 13.5px;
  }
</style>
