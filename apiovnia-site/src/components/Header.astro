---
import Logo from "./Logo.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const nav = [
  { href: `${base}/features`, label: "Features" },
  { href: `${base}/roadmap`,  label: "Roadmap" },
  { href: `${base}/docs`,     label: "Docs" },
  { href: `${base}/download`, label: "Download" },
];

const current = Astro.url.pathname.replace(/\/$/, "");
---
<header class="hdr">
  <div class="container hdr-row">
    <a class="brand" href={`${base}/`} aria-label="Apiovnia home">
      <Logo size={24} />
      <span class="brand-name">Apiovnia</span>
      <span class="brand-tag">alpha</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((item) => {
        const isActive = current === item.href.replace(/\/$/, "");
        return (
          <a class:list={["nav-link", { active: isActive }]} href={item.href}>
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="hdr-right">
      <a
        class="ext"
        href="https://github.com/opalczynski/apiovnia"
        target="_blank"
        rel="noopener"
        aria-label="GitHub repository"
      >
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.4 7.4 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        <span>GitHub</span>
      </a>
    </div>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .hdr-row {
    display: flex;
    align-items: center;
    height: 56px;
    gap: var(--space-5);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--fg);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand:hover { color: var(--fg); }
  .brand-name {
    font-size: 15px;
  }
  .brand-tag {
    font: 600 9.5px/1 var(--mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-bg);
    border: 1px solid var(--accent-bd);
    padding: 3px 5px;
    border-radius: 4px;
  }

  .nav {
    display: flex;
    gap: 2px;
    margin-left: auto;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 12px;
    border-radius: var(--r-ctrl);
    color: var(--fg-dim);
    font: 500 13px/1 var(--ui);
    letter-spacing: -0.005em;
    transition: color .12s, background .12s;
  }
  .nav-link:hover { color: var(--fg); background: var(--hover); }
  .nav-link.active {
    color: var(--fg);
    background: var(--selected);
  }

  .hdr-right { display: flex; align-items: center; gap: var(--space-3); }
  .ext {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 36px;
    padding: 0 12px;
    border-radius: var(--r-ctrl);
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--fg-dim);
    font: 500 13px/1 var(--ui);
    transition: background .12s, border-color .12s, color .12s;
  }
  .ext:hover { background: var(--hover); border-color: var(--border-strong); color: var(--fg); }
  .ext svg { display: block; }

  @media (max-width: 720px) {
    .nav { display: none; }
    .brand-tag { display: none; }
  }
</style>
