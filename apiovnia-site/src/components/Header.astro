---
import Logo from "./Logo.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const nav = [
  { href: `${base}/features`, label: "Features" },
  { href: `${base}/roadmap`,  label: "Roadmap" },
  { href: `${base}/docs`,     label: "Docs" },
  { href: `${base}/download`, label: "Download" },
];

const current = Astro.url.pathname.replace(/\/$/, "");
const isActive = (href: string) => current === href.replace(/\/$/, "");
const gh = "https://github.com/opalczynski/apiovnia";
---
<header class="hdr">
  <div class="container hdr-row">
    <a class="brand" href={`${base}/`} aria-label="Apiovnia home">
      <Logo size={24} />
      <span class="brand-name">Apiovnia</span>
      <span class="brand-tag">alpha</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {nav.map((item) => (
        <a class:list={["nav-link", { active: isActive(item.href) }]} href={item.href}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hdr-right">
      <a class="ext" href={gh} target="_blank" rel="noopener" aria-label="GitHub repository">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.4 7.4 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        <span>GitHub</span>
      </a>

      <button
        class="menu-toggle"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg class="ico-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg class="ico-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown — toggled by .menu-toggle, hidden ≥720px -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile" data-open="false">
    {nav.map((item) => (
      <a class:list={["m-link", { active: isActive(item.href) }]} href={item.href}>
        {item.label}
      </a>
    ))}
    <a class="m-link ext-link" href={gh} target="_blank" rel="noopener">GitHub ↗</a>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
  const panel = document.getElementById("mobile-nav");

  function setOpen(open: boolean) {
    if (!toggle || !panel) return;
    panel.setAttribute("data-open", String(open));
    toggle.setAttribute("aria-expanded", String(open));
  }

  toggle?.addEventListener("click", () => {
    setOpen(panel?.getAttribute("data-open") !== "true");
  });

  // Close on link tap, Escape, or growing back to desktop width.
  panel?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });
  window.matchMedia("(min-width: 721px)").addEventListener("change", (e) => {
    if (e.matches) setOpen(false);
  });
</script>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .hdr-row {
    display: flex;
    align-items: center;
    height: 56px;
    gap: var(--space-5);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--fg);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand:hover { color: var(--fg); }
  .brand-name {
    font-size: 15px;
  }
  .brand-tag {
    font: 600 9.5px/1 var(--mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-bg);
    border: 1px solid var(--accent-bd);
    padding: 3px 5px;
    border-radius: 4px;
  }

  .nav {
    display: flex;
    gap: 2px;
    margin-left: auto;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 12px;
    border-radius: var(--r-ctrl);
    color: var(--fg-dim);
    font: 500 13px/1 var(--ui);
    letter-spacing: -0.005em;
    transition: color .12s, background .12s;
  }
  .nav-link:hover { color: var(--fg); background: var(--hover); }
  .nav-link.active {
    color: var(--fg);
    background: var(--selected);
  }

  .hdr-right { display: flex; align-items: center; gap: var(--space-3); }
  .ext {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 36px;
    padding: 0 12px;
    border-radius: var(--r-ctrl);
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--fg-dim);
    font: 500 13px/1 var(--ui);
    transition: background .12s, border-color .12s, color .12s;
  }
  .ext:hover { background: var(--hover); border-color: var(--border-strong); color: var(--fg); }
  .ext svg { display: block; }

  /* Hamburger — hidden on desktop, shown on mobile */
  .menu-toggle {
    display: none;
    width: 38px;
    height: 38px;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-ctrl);
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--fg-dim);
    cursor: pointer;
    transition: background .12s, border-color .12s, color .12s;
  }
  .menu-toggle:hover { background: var(--hover); border-color: var(--border-strong); color: var(--fg); }
  .menu-toggle .ico-close { display: none; }
  .menu-toggle[aria-expanded="true"] .ico-open { display: none; }
  .menu-toggle[aria-expanded="true"] .ico-close { display: block; }

  /* Mobile dropdown panel */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: var(--space-2) var(--space-5) var(--space-4);
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .mobile-nav[data-open="true"] { display: flex; }
  .m-link {
    display: flex;
    align-items: center;
    height: 44px;
    padding: 0 12px;
    border-radius: var(--r-ctrl);
    color: var(--fg-dim);
    font: 500 15px/1 var(--ui);
    border-bottom: 1px solid var(--border-soft);
  }
  .m-link:last-child { border-bottom: 0; }
  .m-link:hover { color: var(--fg); background: var(--hover); }
  .m-link.active { color: var(--fg); }
  .m-link.active::before {
    content: "";
    width: 3px;
    height: 16px;
    border-radius: 2px;
    background: var(--accent);
    margin-right: 8px;
    margin-left: -12px;
  }
  .ext-link { color: var(--accent); }

  @media (max-width: 720px) {
    .nav { display: none; }
    .ext span { display: none; }       /* GitHub button → icon only */
    .ext { padding: 0; width: 38px; justify-content: center; }
    .brand-tag { display: none; }
    .menu-toggle { display: inline-flex; }
  }
</style>
